OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
MOCK_AI=false
DATABASE_PATH=data/study_assistant.db
# Leave DATABASE_URL empty for local SQLite. Set it for PostgreSQL in production.
DATABASE_URL=
MAX_SOURCE_CHARS=100000
MAX_UPLOAD_MB=10
ACCESS_PASSWORD=
AUTH_TOKEN_SECRET=change_this_to_a_long_random_secret_before_launch
AUTH_TOKEN_TTL_DAYS=14
REQUIRE_USER_ACCOUNTS=false
PER_USER_DAILY_AI_LIMIT=20
GLOBAL_DAILY_AI_LIMIT=100
