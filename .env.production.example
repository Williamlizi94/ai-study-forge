APP_ENV=production

# Keep real AI enabled in production.
MOCK_AI=false
OPENAI_API_KEY=replace_with_openai_project_key
OPENAI_MODEL=gpt-5.4-mini

# Use PostgreSQL in production. Do not use SQLite on AWS containers.
DATABASE_URL=postgresql://user:password@host:5432/study_assistant

# Public SaaS mode.
REQUIRE_USER_ACCOUNTS=true
AUTH_TOKEN_SECRET=replace_with_at_least_32_random_characters
AUTH_TOKEN_TTL_DAYS=14
ACCESS_PASSWORD=

# Optional Google OAuth login. Leave empty until a Google OAuth Client is ready.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# Set this to your deployed domain if the frontend is served separately.
# If FastAPI serves the built frontend from the same domain, this can stay empty.
CORS_ORIGINS=

MAX_SOURCE_CHARS=100000
MAX_UPLOAD_MB=10
PER_USER_DAILY_AI_LIMIT=20
GLOBAL_DAILY_AI_LIMIT=100
